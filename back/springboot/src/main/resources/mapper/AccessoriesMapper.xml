<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.AccessoriesDao">
    <select id="findBySearch" resultType="com.example.entity.Accessories">
        select * from accessories
        <where>
            <if test="params != null and params.accessories != null and params.accessories != ''">
                and accessories like concat('%',#{params.accessories},'%')
            </if>
        </where>
    </select>

</mapper>