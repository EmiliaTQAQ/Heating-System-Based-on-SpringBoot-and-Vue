<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.FeedBackDao">
    <select id="findBySearch" resultType="com.example.entity.FeedBack">
        select * from feedback
        <where>
            <if test="params != null and params.name != null and params.name != ''">
                and user like concat('%',#{params.name},'%')
            </if>
            <if test="params != null and params.state != null and params.state != ''">
                and state like concat('%',#{params.state},'%')
            </if>
        </where>
    </select>

</mapper>