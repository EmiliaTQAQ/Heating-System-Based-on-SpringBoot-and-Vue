<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.MaintainDao">
    <select id="findBySearch" resultType="com.example.entity.Maintain">
        select * from maintain
        <where>
            <if test="params != null and params.name != null and params.name != ''">
                and name like concat('%',#{params.name},'%')
            </if>
        </where>
    </select>
    <select id="findBySearchH" resultType="com.example.entity.Maintain">
        select * from maintain
        <where>
            <if test="params != null and params.name != null and params.name != ''">
                and name = #{params.name}
            </if>
            and heating_account = #{params.heating_account}
        </where>
    </select>


</mapper>